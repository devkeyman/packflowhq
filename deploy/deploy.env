# deploy.env
# 공통 설정 (한 곳에서만 관리)

PROJECT_NAME="packflowhq"
DOMAIN="packflowhq.com"

SERVER_HOST="13.209.192.235"
SERVER_USER="ubuntu"
SERVER="${SERVER_USER}@${SERVER_HOST}"

# SSH Key (deploy 폴더 기준 상대경로)
PEM_FILE="./keys/packflowhq.pem"

# Local project paths (deploy 폴더 기준 상대경로)
FRONTEND_DIR="../frontend"
BACKEND_DIR="../backend"

# Remote paths
REMOTE_FRONTEND_DIR="/opt/packflowhq/frontend"
REMOTE_BACKEND_DIR="/opt/packflowhq/backend"

# Backend
BACKEND_PORT="8080"

# Routing convention (nginx에서 /api → backend로 프록시하는 구조 전제)
API_PREFIX="/api"

# Health endpoint (둘 중 실제 200 나오는 것으로 맞추기)
# 보통은 "/actuator/health"가 정석
HEALTH_PATH="/api/actuator/health"

# 빌드 산출물 폴더명 (Vite: dist, CRA: build)
FRONTEND_BUILD_DIR="dist"

# Backend jar file name
JAR_NAME="packflowhq-0.0.1-SNAPSHOT.jar"

# systemd service name
SERVICE_NAME="packflowhq"